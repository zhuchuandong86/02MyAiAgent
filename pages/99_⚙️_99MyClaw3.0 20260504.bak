st.set_page_config(page_title="Claw Agent OS", page_icon="🐾", layout="wide")

# ── 侧栏 ─────────────────────────────────────────────────────
with st.sidebar:
    st.title("🐾 Claw")

    # 用户切换
    current_user = st.text_input("账户", value=st.session_state.get("claw_user", "public"))
    if current_user != st.session_state.get("claw_user"):
        st.session_state.claw_user = current_user
        st.session_state.pop("claw_msgs", None)
        st.session_state.pop("claw_history", None)
        st.rerun()

    ws = get_workspace()
    st.caption(f"工作区：`{ws}`")
    st.caption(f"Skill目录：`{SKILL_ROOT}`")
    if not os.path.isdir(SKILL_ROOT):
        st.warning(f"⚠️ Skill 目录不存在: {SKILL_ROOT}")

    # 文件上传
    st.markdown("### 📂 文件上传")
    uploaded = st.file_uploader("拖入文件", label_visibility="collapsed")
    if uploaded:
        dst = os.path.join(ws, uploaded.name)
        with open(dst, "wb") as f:
            f.write(uploaded.getbuffer())
        st.success(f"✅ {uploaded.name}")

    # Skill 清单（按钮触发）
    st.markdown("### 🧩 Skills")
    skill_index = scan_skill_index()
    if skill_index:
        for slug, info in skill_index.items():
            if st.button(f"/{slug}", help=info["description"], use_container_width=True):
                st.session_state["_trigger_skill"] = slug
                st.rerun()
    else:
        st.caption(f"无 Skill，放入 `{SKILL_ROOT}/`")

    # 定时任务状态
    st.markdown("### ⏱️ 定时任务")
    try:
        jobs = _get_scheduler().get_jobs()
        if jobs:
            for j in jobs:
                st.code(f"{j.id}\n{j.next_run_time.strftime('%H:%M:%S')}")
        else:
            st.caption("无活跃任务")
    except Exception:
        st.caption("定时引擎未启动")

    st.divider()
    if st.button("🧹 清空对话", use_container_width=True):
        st.session_state.pop("claw_msgs", None)
        st.session_state.pop("claw_history", None)
        st.rerun()
    st.caption(f"模型: `{MODEL}`")

# ── 主界面 ────────────────────────────────────────────────────
st.title("🐾 MyClaw Terminal")

# Session 初始化
ws = get_workspace()
if "claw_msgs" not in st.session_state:
    st.session_state.claw_msgs    = [{"role": "system", "content": build_system_prompt(ws)}]
if "claw_history" not in st.session_state:
    st.session_state.claw_history = []

# 渲染历史
for msg in st.session_state.claw_history:
    with st.chat_message(msg["role"]):
        st.markdown(msg["content"])

st.caption("`/list` 查看 Skills · `/skill名 任务` 激活 Skill · 直接输入任务")

# ── 侧栏按钮触发 ──────────────────────────────────────────────
if "_trigger_skill" in st.session_state:
    slug = st.session_state.pop("_trigger_skill")
    prompt = f"/{slug}"
else:
    prompt = st.chat_input("输入任务…")

if not prompt:
    st.stop()

task = prompt.strip()

# ══════════════════════════════════════════════════════════════
# § 7  命令路由
# ══════════════════════════════════════════════════════════════

st.chat_message("user").markdown(task)
st.session_state.claw_history.append({"role": "user", "content": task})

skill_index = scan_skill_index()

# ── /list ─────────────────────────────────────────────────────
if task == "/list":
    resp = format_skill_list(skill_index)
    with st.chat_message("assistant"):
        st.markdown(resp)
    st.session_state.claw_history.append({"role": "assistant", "content": resp})
    st.stop()

# ── /skill-name [任务] ────────────────────────────────────────
active_skill_slug = None
active_skill_body = ""
user_task = task

if task.startswith("/"):
    parts    = task.split(None, 1)
    slug_raw = parts[0][1:].strip()
    # 大小写不敏感匹配（用户可能输 /XinSheng-Agent）
    slug = next((s for s in skill_index if s.lower() == slug_raw.lower()), slug_raw)
    if slug in skill_index:
        active_skill_slug = slug
        active_skill_body = load_full_skill(slug, skill_index)
        user_task = parts[1] if len(parts) > 1 else "请按 Skill 手册执行标准流程"

        # 展示 Skill 手册
        with st.chat_message("assistant"):
            with st.expander(f"📖 已加载 Skill：{skill_index[slug]['name']}", expanded=True):
                st.markdown(active_skill_body)
        st.toast(f"🧩 Skill 已激活：{slug}")
    else:
        st.error(f"未找到 Skill `{slug}`，输入 `/list` 查看可用列表。")
        st.stop()
else:
    # 自动路由
    matched = route_skill(task, skill_index)
    if matched:
        active_skill_slug = matched
        active_skill_body = load_full_skill(matched, skill_index)
        with st.chat_message("assistant"):
            st.info(f"🧩 自动匹配 Skill：**{skill_index[matched]['name']}** (`/{matched}`)")
    else:
        # 未命中任何 Skill，提示用户可用的 Skill
        if skill_index:
            skills_hint = "、".join(f"`/{s}`" for s in list(skill_index.keys())[:5])
            st.caption(f"💡 未匹配到 Skill，直接执行。可用 Skill：{skills_hint}")

# ══════════════════════════════════════════════════════════════
# § 8  执行引擎（实时输出，不套 st.status）
# ══════════════════════════════════════════════════════════════

# 重建 system prompt（注入 Skill 或刷新经验）
st.session_state.claw_msgs[0] = {
    "role":    "system",
    "content": build_system_prompt(ws, active_skill_body, active_skill_slug or ""),
}

# 注入任务
skill_dir_hint = ""
if active_skill_slug:
    skill_dir_hint = f"\nSkill 脚本目录（execute_shell_command 的 cwd 参数）：{skill_index[active_skill_slug]['path']}"

st.session_state.claw_msgs.append({
    "role": "user",
    "content": (
        f"工作区：{ws}\n"
        f"今日：{datetime.now().strftime('%Y-%m-%d %H:%M')}\n"
        f"{skill_dir_hint}\n\n"
        f"【任务】{user_task}\n"
        + ("\n【重要】执行脚本必须用上方列出的完整绝对路径，禁止猜测脚本位置！" if active_skill_slug else "")
    ),
})

MAX_OUT = 3000

# CSS 样式注入
st.markdown("""<style>
.claw-think { border-left:3px solid #7B68EE; padding:8px 12px; margin:4px 0;
              background:#F0EEFF; border-radius:0 6px 6px 0; font-size:13px; }
.claw-bash  { border-left:3px solid #f0a500; padding:8px 12px; margin:4px 0;
              background:#FDF9E8; border-radius:0 6px 6px 0;
              font-family:monospace; font-size:13px; }
.claw-obs   { border-left:3px solid #2a9d5c; padding:8px 12px; margin:4px 0;
              background:#E9F5EE; border-radius:0 6px 6px 0;
              font-family:monospace; font-size:12px; white-space:pre-wrap; }
.claw-warn  { border-left:3px solid #e74c3c; padding:8px 12px; margin:4px 0;
              background:#FEECEC; border-radius:0 6px 6px 0; font-size:13px; }
.claw-done  { background:#E9F5EE; border:1px solid #2a9d5c; border-radius:8px;
              padding:10px 16px; margin:8px 0; font-weight:bold; }
</style>""", unsafe_allow_html=True)

spin_ph = st.empty()

for step in range(100):
    spin_ph.markdown(f"⏳ **第 {step + 1} 轮推演中…**")

    force = (step < 3)
    try:
        msg = call_llm(st.session_state.claw_msgs, force_tool=force)
    except Exception:
        try:
            msg = call_llm(st.session_state.claw_msgs, force_tool=False)
        except Exception as e2:
            st.markdown(f'<div class="claw-warn">❌ LLM 调用失败：{e2}</div>', unsafe_allow_html=True)
            break

    st.session_state.claw_msgs = trim_messages(st.session_state.claw_msgs + [msg])
    content_text = msg.content or ""

    # ── 修改1：思考过程始终展开显示（紫色）─────────────────
    if content_text:
        spin_ph.empty()
        safe_text = content_text.replace("<", "&lt;").replace(">", "&gt;").replace("\n", "<br>")
        st.markdown(
            f'<div class="claw-think">🧠 <b>第 {step+1} 轮思考</b><br>{safe_text[:1500]}</div>',
            unsafe_allow_html=True
        )

    # ── 无工具调用分支 ────────────────────────────────────────
    if not msg.tool_calls:

        # 文本 JSON 调用代执行
        json_calls = []
        for m in re.finditer(
            r'\{\s*"name"\s*:\s*"(\w+)"\s*,\s*"arguments"\s*:\s*(\{[^{}]*\})',
            content_text
        ):
            try:
                fname = m.group(1)
                args  = json.loads(m.group(2))
                if fname in TOOL_MAP:
                    json_calls.append((fname, args))
            except Exception:
                pass

        if json_calls:
            st.markdown(f'<div class="claw-warn">⚠️ 检测到文本工具调用，代为执行（{len(json_calls)} 个）</div>', unsafe_allow_html=True)
            results = []
            for fname, args in json_calls:
                cmd_str = json.dumps(args, ensure_ascii=False)[:200]
                st.markdown(f'<div class="claw-bash">🛠️ {fname}({cmd_str})</div>', unsafe_allow_html=True)
                res = TOOL_MAP[fname](**args)
                safe_res = str(res).replace("<", "&lt;").replace(">", "&gt;")
                st.markdown(f'<div class="claw-obs">{safe_res[:1500]}</div>', unsafe_allow_html=True)
                results.append(f"[{fname}] {res[:300]}")
            st.session_state.claw_msgs.append({
                "role": "user",
                "content": "系统代执行结果：\n" + "\n\n".join(results) + "\n\n请继续。"
            })
            continue

        # 规划性文字但没调工具 → 强制重试
        planning_signals = [
            "让我", "我来", "我将", "我会", "我先", "首先", "接下来",
            "帮你", "现在", "下面", "稍后", "搜索", "查找", "获取",
            "创建", "编写", "来写", "来搜", "来查", "尝试", "可以通过",
            "I will", "Let me", "I'll", "I can",
        ]
        if step < 5 and content_text and any(s in content_text for s in planning_signals):
            st.markdown('<div class="claw-warn">⚠️ 只说不做，强制重试…</div>', unsafe_allow_html=True)
            st.session_state.claw_msgs.append({
                "role": "user",
                "content": (
                    "【强制执行】你说了要做但没有调用任何工具！禁止只说不做。"
                    "现在立刻调用 execute_shell_command 执行，不要再解释。"
                    f" 工作区：{get_workspace()}"
                )
            })
            continue

        # 真正完成
        spin_ph.empty()
        st.markdown('<div class="claw-done">✅ 任务完成</div>', unsafe_allow_html=True)
        if content_text:
            with st.chat_message("assistant"):
                st.markdown(content_text)
            st.session_state.claw_history.append({"role": "assistant", "content": content_text})

        # 反思写经验
        st.session_state.claw_msgs.append({
            "role": "user",
            "content": "任务完成。将本次有价值的经验（what/why/how）用 execute_shell_command 追加到 memory.jsonl，否则回复「无经验」。"
        })
        try:
            reflect = call_llm(st.session_state.claw_msgs)
            if reflect.tool_calls:
                for tc in reflect.tool_calls:
                    try:
                        res = TOOL_MAP[tc.function.name](**json.loads(tc.function.arguments))
                        st.caption(f"🧠 {res[:60]}")
                    except Exception:
                        pass
        except Exception:
            pass
        break

    # ── 有工具调用：橙色命令 + 绿/红结果 ───────────────────
    for tc in msg.tool_calls:
        fname = tc.function.name
        try:
            args = json.loads(tc.function.arguments)
        except Exception:
            args = {}

        # 命令行（橙色）
        cmd_display = args.get("command", json.dumps(args, ensure_ascii=False))[:400]
        cwd_display = f" · cwd: {args['cwd']}" if args.get("cwd") else ""
        safe_cmd = cmd_display.replace("<", "&lt;").replace(">", "&gt;").replace("\n", "<br>")
        st.markdown(
            f'<div class="claw-bash">🛠️ <b>{fname}</b><span style="color:#888">{cwd_display}</span><br>'
            f'<code style="background:none">{safe_cmd}</code></div>',
            unsafe_allow_html=True
        )

        result     = TOOL_MAP.get(fname, lambda **_: f"❌ 未注册: {fname}")(**args)
        result_str = str(result)

        is_error = any(k in result_str for k in ["❌", "Error", "Traceback", "timed out", "[stderr]"])
        if is_error:
            result_str += "\n\n【🚨 出错！分析原因，换方案重试。连续2次失败请换思路。】"

        if len(result_str) > MAX_OUT:
            half = MAX_OUT // 2
            result_str = result_str[:half] + f"\n…[截断 {len(result_str)} 字符]…\n" + result_str[-half:]

        # 结果（绿色正常 / 红色出错）
        css_cls  = "claw-warn" if is_error else "claw-obs"
        safe_res = result_str[:2000].replace("<", "&lt;").replace(">", "&gt;").replace("\n", "<br>")
        st.markdown(f'<div class="{css_cls}">{safe_res}</div>', unsafe_allow_html=True)

        st.session_state.claw_msgs.append({
            "role": "tool", "tool_call_id": tc.id, "content": result_str
        })

    st.session_state.claw_msgs = trim_messages(st.session_state.claw_msgs)

else:
    st.markdown('<div class="claw-warn">❌ 触碰100轮安全阀，中止</div>', unsafe_allow_html=True)